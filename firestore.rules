rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: schools
    // Fields: name, type
    //
    // Collection: users
    // Fields: email, role, name, student_id, school_id
    //
    // Collection: students
    // Fields: name, class_id, school_id
    //
    // Collection: classes
    // Fields: name, school_id, head_teacher_id
    //
    // Collection: subjects
    // Fields: name, school_id
    //
    // Collection: grades
    // Fields: student_id, subject_id, value, note, date, teacher_id, element_id
    //
    // Collection: absences
    // Fields: student_id, date, hours, reason, status
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (getUserData().role == 'admin' || 
         (request.auth.token.email == "nikoladuric025@gmail.com" && request.auth.token.email_verified == true));
    }

    function isTeacher() {
      return isAuthenticated() && getUserData().role == 'teacher';
    }

    function isParent() {
      return isAuthenticated() && getUserData().role == 'parent';
    }

    function isStudent() {
      return isAuthenticated() && getUserData().role == 'student';
    }

    function belongsToSchool(schoolId) {
      return getUserData().school_id == schoolId;
    }

    // Schools
    match /schools/{schoolId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Users
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Students
    match /students/{studentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isTeacher();
    }

    // Classes
    match /classes/{classId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isTeacher();
    }

    // Subjects
    match /subjects/{subjectId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isTeacher();
    }

    // Grades
    match /grades/{gradeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isTeacher();
    }

    // Absences
    match /absences/{absenceId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isTeacher();
    }
  }
}
