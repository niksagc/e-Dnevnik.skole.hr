rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isHeadTeacher(classId) {
      return isAuthenticated() && get(/databases/$(database)/documents/classes/$(classId)).data.head_teacher == request.auth.uid;
    }
    function isDeputyHeadTeacher(classId) {
      return isAuthenticated() && get(/databases/$(database)/documents/classes/$(classId)).data.deputy_head_teacher == request.auth.uid;
    }
    function canEditClass(classId) {
      return isAdmin() || isHeadTeacher(classId) || isDeputyHeadTeacher(classId);
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /schools/{schoolId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /classes/{classId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if canEditClass(classId);
      allow delete: if isAdmin();
    }
    match /dnevnik_weeks/{weekId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin(); // Needs refinement based on teacher subjects
    }
  }
}
